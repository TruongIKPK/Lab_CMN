<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Quan ly danh muc</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen py-10">
  <div class="max-w-5xl mx-auto space-y-8 px-4">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <p class="text-sm text-slate-500 uppercase tracking-wide">Catalog</p>
        <h1 class="text-3xl font-bold text-slate-900">Danh muc san pham</h1>
        <p class="text-sm text-slate-500 mt-1">Xoa danh muc se <strong>khong xoa san pham</strong> theo business rule.</p>
      </div>
      <div class="flex gap-3">
        <a href="/products" class="text-sm text-slate-500 hover:text-slate-800"><- Quay lai san pham</a>
        <a href="/categories/create" class="bg-blue-600 text-white px-5 py-3 rounded-xl font-semibold hover:bg-blue-700">Them danh muc</a>
      </div>
    </div>

    <% if (error) { %>
      <div class="bg-red-100 border border-red-300 text-red-700 px-6 py-3 rounded-lg">
        <%= error %>
      </div>
    <% } %>

    <div class="bg-white shadow rounded-2xl overflow-hidden">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-6 py-4 text-left">Ten</th>
            <th class="px-6 py-4 text-left">Mo ta</th>
            <th class="px-6 py-4 text-left">San pham dang dung</th>
            <th class="px-6 py-4 text-left">Thao tac</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% if (categories && categories.length > 0) { %>
            <% categories.forEach((category) => { %>
              <tr class="hover:bg-slate-50">
                <td class="px-6 py-4">
                  <p class="font-semibold text-slate-900"><%= category.name %></p>
                  <p class="text-xs text-slate-500">#<%= category.categoryId %></p>
                </td>
                <td class="px-6 py-4 text-sm text-slate-600"><%= category.description || 'Chua cap nhat' %></td>
                <td class="px-6 py-4">
                  <span class="px-3 py-1 rounded-full text-xs font-semibold bg-slate-100 text-slate-700">
                    <%= category.productCount || 0 %> san pham
                  </span>
                </td>
                <td class="px-6 py-4 text-sm flex flex-col gap-2">
                  <a href="/categories/edit/<%= category.categoryId %>" class="text-blue-600 hover:text-blue-800">Chinh sua</a>
                  <form action="/categories/delete/<%= category.categoryId %>" method="post" onsubmit="return confirm('Xoa danh muc nay? San pham se duoc giu nguyen.');">
                    <button type="submit" class="text-red-600 hover:text-red-800">Xoa</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4" class="px-6 py-10 text-center text-slate-500">Chua co danh muc nao.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
