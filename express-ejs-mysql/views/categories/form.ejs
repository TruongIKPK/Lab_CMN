<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= action === 'edit' ? 'Cap nhat danh muc' : 'Tao danh muc' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen py-10">
  <div class="max-w-3xl mx-auto bg-white shadow-xl rounded-2xl p-10 space-y-6">
    <div>
      <p class="text-sm text-slate-500 uppercase tracking-wide">Danh muc</p>
      <h1 class="text-3xl font-bold text-slate-900">
        <%= action === 'edit' ? 'Chinh sua danh muc' : 'Them danh muc moi' %>
      </h1>
      <% if (category && category.categoryId) { %>
        <p class="text-xs text-slate-400">ID: <%= category.categoryId %></p>
      <% } %>
    </div>

    <% if (error) { %>
      <div class="bg-red-100 border border-red-300 text-red-700 px-6 py-3 rounded-lg">
        <%= error %>
      </div>
    <% } %>

    <form method="post" action="<%= action === 'edit' ? '/categories/update/' + category.categoryId : '/categories' %>" class="space-y-5">
      <div>
        <label class="block text-sm text-slate-500 mb-2">Ten danh muc</label>
        <input name="name" value="<%= category ? category.name : '' %>" required class="w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-sm text-slate-500 mb-2">Mo ta</label>
        <textarea name="description" rows="4" class="w-full border rounded-xl px-4 py-3"><%= category ? category.description : '' %></textarea>
      </div>
      <div class="flex gap-4">
        <button class="bg-blue-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-blue-700">
          <%= action === 'edit' ? 'Cap nhat' : 'Tao moi' %>
        </button>
        <a href="/categories" class="bg-slate-100 text-slate-700 px-6 py-3 rounded-xl hover:bg-slate-200">Huy</a>
      </div>
    </form>
  </div>
</body>
</html>
