<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Chinh sua san pham</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen py-12">
  <div class="max-w-3xl mx-auto bg-white shadow-xl rounded-2xl p-10 space-y-8">
    <div>
      <p class="text-sm text-slate-500 uppercase tracking-wide">Cap nhat san pham</p>
      <h1 class="text-3xl font-bold text-slate-900"><%= product.name %></h1>
      <p class="text-slate-500 text-sm mt-1">ID: <%= product.id %></p>
    </div>

    <form action="/products/update/<%= product.id %>" method="post" enctype="multipart/form-data" class="space-y-5">
      <div>
        <label class="block text-sm text-slate-500 mb-2">Ten san pham</label>
        <input name="name" value="<%= product.name %>" required class="w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500">
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm text-slate-500 mb-2">Gia</label>
          <input name="price" type="number" step="0.01" value="<%= product.price %>" required class="w-full border rounded-xl px-4 py-3">
        </div>
        <div>
          <label class="block text-sm text-slate-500 mb-2">So luong</label>
          <input name="quantity" type="number" value="<%= product.quantity %>" required class="w-full border rounded-xl px-4 py-3">
        </div>
        <div>
          <label class="block text-sm text-slate-500 mb-2">Danh muc</label>
          <select name="categoryId" required class="w-full border rounded-xl px-4 py-3">
            <% (categories || []).forEach((category) => { %>
              <option value="<%= category.categoryId %>" <%= category.categoryId === product.categoryId ? 'selected' : '' %>>
                <%= category.name %>
              </option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <p class="text-sm text-slate-500 mb-2">Anh hien tai</p>
          <% if (product.imageUrl) { %>
            <img src="<%= product.imageUrl %>" alt="Anh hien tai" class="h-48 w-full object-cover rounded-xl border" />
          <% } else { %>
            <div class="h-48 flex items-center justify-center border-2 border-dashed rounded-xl text-slate-400">
              Chua co anh
            </div>
          <% } %>
        </div>
        <div>
          <label class="block text-sm text-slate-500 mb-2">Chon anh moi</label>
          <input name="image" type="file" accept="image/*" class="w-full border rounded-xl px-4 py-3">
          <p class="text-xs text-slate-400 mt-2">Neu bo trong, anh cu se duoc giu lai.</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-4">
        <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-blue-700">
          Luu thay doi
        </button>
        <a href="/products" class="bg-slate-100 text-slate-700 px-6 py-3 rounded-xl hover:bg-slate-200">
          Quay lai
        </a>
      </div>
    </form>
  </div>
</body>
</html>