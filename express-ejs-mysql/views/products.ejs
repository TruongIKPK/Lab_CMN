<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Product List</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-8">

  <div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-800 mb-8">Product Management</h1>

    <!-- Add Product Form -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-xl font-semibold mb-4">Add Product</h2>
      <form action="/products/add" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-4 gap-4">
         <input name="name" placeholder="Name" required
           class="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
         <input name="price" type="number" step="0.01" placeholder="Price" required
           class="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
         <input name="quantity" type="number" placeholder="Quantity" required
           class="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
         <input name="image" type="file" accept="image/*" class="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
         <button class="bg-blue-500 text-white px-6 py-2 rounded-lg hover:bg-blue-600 transition">
           Add Product
         </button>
      </form>
    </div>

    <!-- Products Table -->
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <h2 class="text-xl font-semibold p-6 border-b">Products</h2>
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Quantity</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Image</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% products.forEach(p => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4"><%= p.id %></td>
              <td class="px-6 py-4"><%= p.name %></td>
              <td class="px-6 py-4">$<%= p.price %></td>
              <td class="px-6 py-4"><%= p.quantity %></td>
              <td class="px-6 py-4">
                <% if (p.s3_truong) { %>
                  <img src="<%= p.s3_truong %>" alt="Image" class="h-16 w-16 object-cover rounded" />
                <% } else { %>
                  <span class="text-gray-400">No image</span>
                <% } %>
              </td>
              <td class="px-6 py-4">
                 <a href="/products/edit/<%= p.id %>"
                   class="text-blue-600 hover:text-blue-800 mr-4">Edit</a>
                 <form action="/products/delete/<%= p.id %>" method="post" class="inline">
                  <button type="submit"
                          onclick="return confirm('Delete this product?')"
                          class="text-red-600 hover:text-red-800">
                    Delete
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>