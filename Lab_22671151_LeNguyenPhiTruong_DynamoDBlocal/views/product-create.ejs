<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
</head>

<body>
    <main class="page">
        <section class="hero">
            <p class="kicker">Create Product</p>
            <h1 class="headline">
                <%= title %>
            </h1>
            <div class="hero-actions">
                <a class="btn btn-light" href="/">Quay lai danh sach</a>
            </div>
        </section>

        <section class="grid">
            <article class="card card-deep" style="grid-column: 1 / -1;">
                <% if (errorMessage) { %>
                    <p class="form-error">
                        <%= errorMessage %>
                    </p>
                    <% } %>
                        <form class="product-form" method="post" action="/products/new" enctype="multipart/form-data">


                            <label for="name">Name</label>
                            <input id="name" name="name" type="text" required value="<%= product && product.name ? product.name : '' %>" />

                            <label for="price">Price</label>
                            <input id="price" name="price" type="number" min="0" required value="<%= product && product.price ? product.price : '' %>" />

                            <label for="unit_in_stock">Unit In Stock</label>
                            <input id="unit_in_stock" name="unit_in_stock" type="number" min="0" required value="<%= product && product.unit_in_stock ? product.unit_in_stock : '' %>" />

                            <label for="image">Image File (luu vao public/images)</label>
                            <input id="image" name="image" type="file" accept="image/*" required />

                            <button class="btn btn-dark" type="submit">Luu san pham</button>
                        </form>
            </article>
        </section>
    </main>
</body>

</html>